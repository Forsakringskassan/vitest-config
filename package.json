{
  "name": "@forsakringskassan/vitest-config-monorepo",
  "version": "2.5.0",
  "private": true,
  "description": "Försäkringskassan shareable config for Vitest",
  "keywords": [
    "vitest"
  ],
  "homepage": "https://github.com/Forsakringskassan/vitest-config#readme",
  "bugs": {
    "url": "https://github.com/Forsakringskassan/vitest-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/vitest-config.git"
  },
  "license": "MIT",
  "author": "Föräkringskassan",
  "type": "module",
  "files": [],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "lerna run build",
    "eslint": "eslint .",
    "eslint:fix": "eslint --fix .",
    "lint": "run-s prettier:check eslint",
    "lint:fix": "run-s prettier:write eslint:fix",
    "prepare": "commitlint-config",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "pretest": "npm run lint",
    "test": "true",
    "preversion": "bash scripts/preversion"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-monorepo-config"
  },
  "devDependencies": {
    "@forsakringskassan/commitlint-config": "4.1.2",
    "@forsakringskassan/eslint-config": "15.2.0",
    "@forsakringskassan/prettier-config": "3.7.6",
    "@html-validate/release-scripts": "7.3.1",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "22.20.0",
    "lerna": "9.0.7",
    "npm-pkg-lint": "5.1.10",
    "npm-run-all2": "9.0.2",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">= 22.12.0",
    "npm": ">= 10.0.0"
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": false,
    "nx": false,
    "unrs-resolver": true
  }
}
